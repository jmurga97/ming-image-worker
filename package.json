{
  "name": "ming-image-worker",
  "description": "Private multi-product image upload and optimization service for Cloudflare Workers",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "wrangler dev --remote --port 8790 --inspector-port 9233",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "bun run db:migrate && wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply DB --remote",
    "check": "tsc --noEmit",
    "test": "bun test",
    "lint": "bun run lint:prettier && bun run lint:eslint",
    "lint:prettier": "prettier --check .",
    "lint:eslint": "eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.3.0",
    "aws4fetch": "^1.0.20",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.11.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bun": "^1.3.6",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.6.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "wrangler": "^4.60.0"
  },
  "packageManager": "bun@1.3.6"
}
